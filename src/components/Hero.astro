---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  eyebrow?: string;
  headline: string;
  subhead?: string;
  ctaLabel?: string;
  ctaHref?: string;
  align?: 'left' | 'center';
  height?: 'full' | 'short';
}

const {
  image,
  alt,
  eyebrow,
  headline,
  subhead,
  ctaLabel,
  ctaHref,
  align = 'center',
  height = 'full',
} = Astro.props;
---

<section class:list={['hero', `hero-${height}`]}>
  <Picture
    src={image}
    alt={alt}
    widths={[640, 960, 1280, 1920, 2560]}
    sizes="100vw"
    formats={['avif', 'webp', 'jpg']}
    loading="eager"
    fetchpriority="high"
    class="hero-img"
  />
  <div class="hero-scrim"></div>
  <div class:list={['wrap', 'hero-content', `align-${align}`]}>
    <h1 class="hero-headline">{headline}</h1>
    {subhead && <p class="hero-subhead">{subhead}</p>}
    {ctaLabel && ctaHref && (
      <a href={ctaHref} class="btn btn-solid hero-cta" {...(ctaHref.startsWith('http') ? { target: '_blank', rel: 'noopener' } : {})}>{ctaLabel}</a>
    )}
  </div>
  {height === 'full' && (
    <div class="hero-chevron" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 9l6 6 6-6" />
      </svg>
    </div>
  )}
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-full {
    min-height: 100svh;
  }
  .hero-short {
    min-height: 56svh;
  }

  .hero :global(picture),
  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  .hero :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(22, 32, 28, 0.45) 0%,
      rgba(22, 32, 28, 0.35) 45%,
      rgba(22, 32, 28, 0.82) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: calc(var(--nav-height) + 2rem);
    padding-bottom: 3rem;
    color: #fff;
  }
  .align-center {
    text-align: center;
  }
  .align-center .hero-headline,
  .align-center .hero-subhead {
    margin-left: auto;
    margin-right: auto;
  }
  .align-left {
    max-width: 46rem;
  }

  .hero-eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: clamp(0.85rem, 1.6vw, 1.1rem);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold-soft);
    margin: 0 0 1rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }
  .hero-headline {
    font-size: var(--text-hero);
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5em;
    max-width: 22ch;
    white-space: pre-line;
    text-shadow: 0 3px 16px rgba(0, 0, 0, 0.45);
  }
  .hero-short .hero-headline {
    font-size: var(--text-3xl);
  }
  .hero-subhead {
    font-size: var(--text-lg);
    font-weight: 300;
    line-height: 1.9;
    color: rgba(255, 255, 255, 0.92);
    max-width: 40rem;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.4);
  }
  .hero-cta {
    margin-top: 1.6rem;
  }

  .hero-chevron {
    position: absolute;
    bottom: 1.8rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: var(--gold-soft);
    animation: bob 1.8s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 8px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-chevron { animation: none; }
  }
</style>
