---
import { ui } from '../i18n/ui';
import { siteConfig, getSignupUrl } from '../config';

const locale = (Astro.currentLocale ?? 'en') as 'en' | 'ja';
const t = ui[locale];

const path = Astro.url.pathname;
const slugPath = path.startsWith('/ja') ? path.slice(3) || '/' : path;
const currentSlug = slugPath === '/' ? '' : slugPath.replace(/^\//, '').replace(/\/$/, '');

const links = [
  { key: 'about', slug: '', activeSlug: 'about' },
  { key: 'programs', slug: 'programs', activeSlug: 'programs' },
  { key: 'events', slug: 'events', activeSlug: 'events' },
  { key: 'members', slug: 'members', activeSlug: 'members', enOnly: true },
  { key: 'getInvolved', slug: 'get-involved', activeSlug: 'get-involved' },
] as const;

// Slugs that only exist in English (no /ja mirror).
const enOnlySlugs = ['members'];

function hrefFor(targetLocale: 'en' | 'ja', slug: string) {
  if (enOnlySlugs.includes(slug)) return `/${slug}`;
  if (targetLocale === 'ja') return slug ? `/ja/${slug}` : '/ja';
  return slug ? `/${slug}` : '/';
}

const otherLocale = locale === 'ja' ? 'en' : 'ja';
// On an EN-only page the other locale has no mirror — send to its home instead.
const otherLocaleHref = enOnlySlugs.includes(currentSlug)
  ? hrefFor(otherLocale, '')
  : hrefFor(otherLocale, currentSlug);
const brandMain = 'Japan-Africa';
const brandSub = 'Young Professionals';

const signup = getSignupUrl(locale);
const signupExternal = signup.startsWith('http');
---

<header id="site-nav" class="site-nav">
  <div class="wrap nav-inner">
    <a class="brand" href={hrefFor(locale, '')}>
      <img src="/logo.png" alt="JAYP logo" class="brand-logo" width="48" height="48" />
      <span class="brand-text">
        <span class="brand-tag">JAYP</span>
        <span class="brand-name">{brandMain}</span>
        <span class="brand-sub">{brandSub}</span>
      </span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" hidden />
    <label for="nav-toggle" class="nav-toggle-btn" aria-label="Menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="nav-links">
      {links.map((link) => (
        <a
          href={hrefFor(locale, link.slug)}
          class:list={['nav-link', { active: link.activeSlug === currentSlug }]}
        >
          {t.nav[link.key]}
        </a>
      ))}
      <a
        href={signup}
        class="nav-cta"
        {...(signupExternal ? { target: '_blank', rel: 'noopener' } : {})}
      >{t.cta}</a>
      <a href={otherLocaleHref} class="lang-link" aria-label="Switch language" data-set-lang={otherLocale}>
        {t.langSwitchLabel}
      </a>
    </nav>
  </div>
</header>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(244, 237, 216, 0.82);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .site-nav.scrolled {
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 6px 24px -16px rgba(30, 43, 38, 0.6);
    border-bottom-color: var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
    gap: 1rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--text);
  }
  .brand:hover {
    color: var(--text);
  }
  .brand-logo {
    width: 46px;
    height: 46px;
    border-radius: 999px;
    border: 2px solid var(--gold);
    object-fit: cover;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }
  .brand:hover .brand-logo {
    transform: scale(1.05);
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .brand-tag {
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    color: var(--gold-dark);
  }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
  }
  .brand-sub {
    font-size: 0.58rem;
    letter-spacing: 0.03em;
    color: var(--text-soft);
  }

  .nav-toggle-input {
    display: none;
  }
  .nav-toggle-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
  }
  .nav-toggle-btn span {
    width: 24px;
    height: 2px;
    background: var(--text);
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.35rem;
  }
  .nav-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text);
    position: relative;
    padding-bottom: 2px;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--gold-dark);
  }
  .nav-link.active {
    color: var(--gold-dark);
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 2px;
    background: var(--gold);
  }
  .nav-cta {
    font-family: var(--font-label);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    background: var(--gold);
    padding: 0.6em 1.25em;
    border-radius: 999px;
    white-space: nowrap;
    transition: background 0.25s ease, transform 0.2s ease;
  }
  .nav-cta:hover {
    background: var(--gold-dark);
    color: #fff;
    transform: translateY(-1px);
  }
  .lang-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.35em 0.8em;
    background: rgba(255, 255, 255, 0.5);
  }
  .lang-link:hover {
    border-color: var(--gold);
    color: var(--gold-dark);
  }

  @media (max-width: 1100px) {
    .nav-toggle-btn {
      display: flex;
    }
    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
      box-shadow: 0 14px 30px -20px rgba(30, 43, 38, 0.7);
    }
    .nav-toggle-input:checked ~ .nav-links {
      max-height: 32rem;
    }
    .nav-link {
      padding: 1rem var(--content-padding);
      border-bottom: 1px solid var(--border);
    }
    .nav-link.active::after {
      display: none;
    }
    .nav-link.active {
      border-left: 3px solid var(--gold);
      padding-left: calc(var(--content-padding) - 3px);
    }
    .nav-cta {
      margin: 1rem var(--content-padding) 0.5rem;
      text-align: center;
      padding: 0.9em;
    }
    .lang-link {
      margin: 0 var(--content-padding) 1.2rem;
      text-align: center;
      padding: 0.7em;
    }
  }
</style>
