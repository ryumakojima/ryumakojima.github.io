---
interface Bar {
  label: string;
  display: string;
  pct: number; // 0-100, bar height
}
interface Props {
  title: string;
  bars: Bar[];
  source: string;
}
const { title, bars, source } = Astro.props;
---

<figure class="minibars reveal">
  <figcaption class="mb-title">{title}</figcaption>
  <div class="mb-plot">
    {bars.map((b, i) => (
      <div class="mb-col">
        <span class="mb-value">{b.display}</span>
        <div class="mb-bar" style={`--h:${b.pct}%; --i:${i}`}></div>
        <span class="mb-label">{b.label}</span>
      </div>
    ))}
  </div>
  <p class="mb-source">{source}</p>
</figure>

<style>
  .minibars {
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem 1.6rem 1.2rem;
    max-width: 27rem;
  }
  .mb-title {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-dark);
    margin-bottom: 1rem;
  }
  .mb-plot {
    display: flex;
    align-items: flex-end;
    justify-content: space-around;
    gap: clamp(0.7rem, 4vw, 2rem);
    height: 160px;
  }
  .mb-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    flex: 1;
    height: 100%;
  }
  .mb-value {
    font-family: var(--font-label);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--text);
    margin-bottom: 0.4rem;
    white-space: nowrap;
  }
  .mb-bar {
    width: 100%;
    max-width: 3.2rem;
    height: var(--h); /* no-JS fallback: show full bar */
    min-height: 6px;
    background: linear-gradient(180deg, var(--gold) 0%, var(--gold-dark) 100%);
    border-radius: 4px 4px 0 0;
  }
  /* With JS: start at 0 and grow up when scrolled into view */
  :global(.js) .mb-bar {
    height: 0;
    transition: height 0.95s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: calc(var(--i) * 130ms);
  }
  :global(.js) .minibars.is-visible .mb-bar {
    height: var(--h);
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.js) .mb-bar {
      transition: none;
      height: var(--h);
    }
  }
  .mb-label {
    font-size: var(--text-sm);
    color: var(--text-soft);
    margin-top: 0.5rem;
  }
  .mb-source {
    font-size: 0.72rem;
    line-height: 1.5;
    color: var(--text-soft);
    margin: 1rem 0 0;
  }
</style>
