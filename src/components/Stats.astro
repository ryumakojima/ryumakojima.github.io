---
interface Stat {
  value: number;
  suffix?: string;
  label: string;
}
interface Props {
  items: Stat[];
}
const { items } = Astro.props;
---

<div class="stats">
  {items.map((s, i) => (
    <>
      {i > 0 && <span class="stat-div" aria-hidden="true"></span>}
      <div class="stat">
        <span class="stat-num">
          <span class="num" data-count={s.value}>0</span>{s.suffix}
        </span>
        <span class="stat-label">{s.label}</span>
      </div>
    </>
  ))}
</div>

<style>
  .stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1.5rem, 6vw, 5rem);
    flex-wrap: wrap;
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .stat-num {
    font-family: var(--font-label);
    font-weight: 700;
    font-size: clamp(2.8rem, 8vw, 4.6rem);
    line-height: 1;
    color: var(--gold);
    letter-spacing: 0.01em;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    margin-top: 0.7rem;
    font-size: var(--text-sm);
    letter-spacing: 0.06em;
    color: var(--text-on-dark-soft);
    text-transform: uppercase;
  }
  .stat-div {
    width: 1px;
    height: 3.5rem;
    background: rgba(255, 255, 255, 0.15);
  }
  @media (max-width: 560px) {
    .stat-div {
      display: none;
    }
    .stats {
      gap: 2.5rem 3rem;
    }
  }
</style>
