---
const ICONS: Record<string, string> = {
  language: '<path d="M3 5h12M9 3v2m1.5 0c0 4-2.5 8-7.5 10M5 9c0 2.5 2.5 5 6 6.5M14 19l4-9 4 9M15.5 16h5"/>',
  culture: '<path d="M3 21h18M5 21V10l7-5 7 5v11M9 21v-5h6v5"/>',
  exchange: '<path d="M4 8h13l-3-3m3 3-3 3M20 16H7l3-3m-3 3 3 3"/>',
  visit: '<path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  students: '<path d="M12 3 2 8l10 5 10-5-10-5ZM6 10.5V15c0 1.7 2.7 3 6 3s6-1.3 6-3v-4.5"/>',
  volunteer: '<path d="M12 21s-6.5-4.4-9-8.5C1.3 9.6 2.5 6 6 6c2 0 3 1.2 3.8 2.3C10.6 7.2 11.6 6 13.6 6c3.5 0 4.7 3.6 3 6.5C19 16.6 12 21 12 21Z"/>',
  partner: '<path d="M8 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM2 20c0-3 2.7-5 6-5s6 2 6 5M16 6a3 3 0 0 1 1 5.8M22 20c0-2.4-1.6-4.2-4-4.8"/>',
  calendar: '<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v4M16 3v4"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  network: '<circle cx="6" cy="6" r="2.5"/><circle cx="18" cy="6" r="2.5"/><circle cx="12" cy="18" r="2.5"/><path d="M8 6h8M7.7 8 10.7 16M16.3 8 13.3 16"/>',
  sports: '<circle cx="12" cy="12" r="9"/><path d="m12 7 3.5 2.5-1.3 4.2H9.8L8.5 9.5 12 7Z"/><path d="M12 3v4M3.5 9.5l4.9 0.0M20.5 9.5l-4.9 0M6.5 19l3.3-2.8M17.5 19l-3.3-2.8"/>',
  business: '<rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M3 12h18"/>',
};

interface CardItem {
  heading: string;
  body: string;
  meta?: string;
  ctaLabel?: string;
  ctaHref?: string;
  icon?: string;
  accent?: 'gold' | 'accent' | 'green';
}

interface Props {
  items: CardItem[];
  columns?: 2 | 3 | 4;
  onDark?: boolean;
}

const { items, columns = 3, onDark = false } = Astro.props;
---

<div class:list={['card-grid', { 'on-dark': onDark }]} style={`--cols:${columns}`}>
  {items.map((item, i) => (
    <article
      class:list={['card', 'reveal', `accent-${item.accent ?? 'gold'}`]}
      style={`transition-delay:${i * 90}ms`}
    >
      {item.icon && ICONS[item.icon] && (
        <span class="card-icon" set:html={`<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${ICONS[item.icon]}</svg>`}></span>
      )}
      {item.meta && <p class="card-meta">{item.meta}</p>}
      <h3 class="card-heading">{item.heading}</h3>
      <p class="card-body">{item.body}</p>
      {item.ctaLabel && item.ctaHref && (
        <a href={item.ctaHref} class="card-link" {...(item.ctaHref.startsWith('http') ? { target: '_blank', rel: 'noopener' } : {})}>{item.ctaLabel}
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      )}
    </article>
  ))}
</div>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
    gap: 1.6rem;
  }

  .card {
    background: var(--paper);
    border-radius: 12px;
    border-bottom: 4px solid var(--gold);
    padding: 2rem 1.8rem;
    box-shadow: 0 18px 40px -30px rgba(30, 43, 38, 0.5);
    transition: transform 0.3s ease, box-shadow 0.3s ease, opacity 0.8s ease-out;
    display: flex;
    flex-direction: column;
  }
  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 28px 50px -28px rgba(30, 43, 38, 0.5);
  }
  .accent-gold { border-bottom-color: var(--gold); }
  .accent-accent { border-bottom-color: var(--accent); }
  .accent-green { border-bottom-color: var(--green); }

  .card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.1rem;
    height: 3.1rem;
    border-radius: 999px;
    margin-bottom: 1.1rem;
    background: var(--sand-deep);
    color: var(--gold-dark);
    transition: background 0.3s ease, color 0.3s ease;
  }
  .accent-accent .card-icon { color: var(--accent); }
  .accent-green .card-icon { color: var(--green); }
  .card:hover .card-icon {
    background: var(--gold);
    color: #fff;
  }
  .accent-accent:hover .card-icon { background: var(--accent); }
  .accent-green:hover .card-icon { background: var(--green); }

  .card-meta {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold-dark);
    margin: 0 0 0.5em;
  }
  .card-heading {
    font-size: var(--text-xl);
    margin-bottom: 0.5em;
  }
  .card-body {
    color: var(--text-soft);
    font-size: var(--text-sm);
    margin-bottom: 0;
    flex-grow: 1;
  }
  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.2rem;
    font-family: var(--font-label);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold-dark);
  }
  .card-link svg { transition: transform 0.25s ease; }
  .card-link:hover svg { transform: translateX(3px); }

  /* Dark-section variant (translucent glass cards) */
  .on-dark .card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 4px solid var(--gold);
    box-shadow: none;
  }
  .on-dark .accent-accent { border-bottom-color: var(--accent); }
  .on-dark .accent-green { border-bottom-color: var(--green); }
  .on-dark .card:hover {
    background: rgba(255, 255, 255, 0.09);
  }
  .on-dark .card-heading { color: #fff; }
  .on-dark .card-body { color: var(--text-on-dark-soft); }
  .on-dark .card-icon {
    background: rgba(255, 255, 255, 0.08);
    color: var(--gold);
  }

  @media (max-width: 900px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
