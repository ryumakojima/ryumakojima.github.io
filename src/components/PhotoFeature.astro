---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import SectionLabel from './SectionLabel.astro';

interface Props {
  image?: ImageMetadata;
  placeholder?: string;
  alt: string;
  eyebrow?: string;
  heading: string;
  ctaLabel?: string;
  ctaHref?: string;
  flip?: boolean;
  ratio?: '43' | '32' | '11' | '169' | 'portrait';
  caption?: string;
}

const {
  image,
  placeholder,
  alt,
  eyebrow,
  heading,
  ctaLabel,
  ctaHref,
  flip = false,
  ratio = '43',
  caption,
} = Astro.props;
---

<section class:list={['feature', 'wrap', 'reveal', { flip }]}>
  <div class="feature-media">
    <div class="feature-frame">
      <div class:list={['ratio', `ratio-${ratio}`]}>
        {image ? (
          <Picture
            src={image}
            alt={alt}
            widths={[400, 640, 960, 1280]}
            sizes="(min-width: 900px) 50vw, 100vw"
            formats={['avif', 'webp', 'jpg']}
            loading="lazy"
          />
        ) : (
          <img src={placeholder} alt={alt} loading="lazy" />
        )}
      </div>
      {caption && (
        <div class="feature-caption">
          <span>{caption}</span>
        </div>
      )}
    </div>
  </div>

  <div class="feature-text">
    {eyebrow ? (
      <SectionLabel eyebrow={eyebrow} heading={heading} />
    ) : (
      <h2 class="feature-heading">{heading}</h2>
    )}
    <div class="feature-body">
      <slot />
    </div>
    {ctaLabel && ctaHref && (
      <a href={ctaHref} class="feature-cta" {...(ctaHref.startsWith('http') ? { target: '_blank', rel: 'noopener' } : {})}>{ctaLabel}
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    )}
  </div>
</section>

<style>
  .feature {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    padding-block: clamp(3rem, 7vw, 5.5rem);
  }

  .feature-media {
    order: 1;
  }
  .feature-text {
    order: 2;
  }
  .feature.flip .feature-media {
    order: 2;
  }
  .feature.flip .feature-text {
    order: 1;
  }

  .feature-frame {
    position: relative;
    border: 6px double rgba(197, 160, 89, 0.5);
    padding: 8px;
    border-radius: 6px;
    background: var(--paper);
    box-shadow: 0 24px 50px -28px rgba(30, 43, 38, 0.55);
    transform: rotate(-0.8deg);
    transition: transform 0.5s ease;
  }
  .feature.flip .feature-frame {
    transform: rotate(0.8deg);
  }
  .feature-frame:hover {
    transform: rotate(0);
  }
  .feature-frame .ratio {
    border-radius: 3px;
  }

  .feature-caption {
    position: absolute;
    left: 8px;
    right: 8px;
    bottom: 8px;
    padding: 1.6rem 1.2rem 0.9rem;
    background: linear-gradient(to top, rgba(22, 32, 28, 0.85), transparent);
    border-radius: 0 0 3px 3px;
  }
  .feature-caption span {
    color: #fff;
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .feature-heading {
    font-size: var(--text-2xl);
  }
  .feature-body :global(p) {
    color: var(--text-soft);
    margin-bottom: 1em;
  }
  .feature-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: var(--text-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold-dark);
    margin-top: 0.4rem;
  }
  .feature-cta svg {
    transition: transform 0.25s ease;
  }
  .feature-cta:hover svg {
    transform: translateX(4px);
  }

  @media (max-width: 900px) {
    .feature {
      grid-template-columns: 1fr;
      gap: 1.8rem;
    }
    .feature-media,
    .feature.flip .feature-media {
      order: 1;
    }
    .feature-text,
    .feature.flip .feature-text {
      order: 2;
    }
  }
</style>
