---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ui } from '../i18n/ui';
import { siteConfig } from '../config';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  keywords?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  enOnly?: boolean; // page has no /ja mirror — skip the ja hreflang alternate
}

const { title, description, keywords = [], jsonLd = [], enOnly = false } = Astro.props;
const locale = (Astro.currentLocale ?? 'en') as 'en' | 'ja';
const t = ui[locale];

const site = Astro.site;
const pathname = Astro.url.pathname;
const abs = (p: string) => (site ? new URL(p, site).href : p);

const canonical = abs(pathname);
const slug = pathname.startsWith('/ja') ? pathname.slice(3) || '/' : pathname;
const enPath = slug;
const jaPath = slug === '/' ? '/ja' : `/ja${slug}`;

const ogImage = abs('/og.jpg');
const ogLocale = locale === 'ja' ? 'ja_JP' : 'en_US';
const ogLocaleAlt = locale === 'ja' ? 'en_US' : 'ja_JP';
const siteName = locale === 'ja' ? siteConfig.nameJa : siteConfig.name;
const defaultKeywords =
  locale === 'ja'
    ? [
        '日本 アフリカ 交流',
        '日本 アフリカ コミュニティ',
        '在日アフリカ コミュニティ',
        'アフリカ イベント 日本',
        '国際交流 日本 アフリカ',
        'Japan-Africa Young Professionals',
      ]
    : [
        'Japan Africa community',
        'Japan-Africa events',
        'African community in Japan',
        'Africa networking Japan',
        'international exchange Japan Africa',
        'Japan-Africa Young Professionals',
      ];
const metaKeywords = [...new Set([...keywords, ...defaultKeywords])].join(', ');

const sameAs = [siteConfig.instagram, siteConfig.x, siteConfig.founder.url].filter(Boolean);
const orgId = abs('/#organization');
const websiteId = abs('/#website');
const pageId = `${canonical}#webpage`;
const orgLd = {
  '@type': 'Organization',
  '@id': orgId,
  name: siteConfig.name,
  alternateName: [siteConfig.nameJa, siteConfig.shortName, ...siteConfig.aliases],
  url: site ? site.href : undefined,
  logo: abs('/logo.png'),
  description,
  ...(sameAs.length ? { sameAs } : {}),
};
const websiteLd = {
  '@type': 'WebSite',
  '@id': websiteId,
  url: site ? site.href : undefined,
  name: siteConfig.name,
  alternateName: [siteConfig.nameJa, siteConfig.shortName, ...siteConfig.aliases],
  description:
    'A Japan-Africa exchange community site for networking events, cultural exchange, and sports in Japan.',
  inLanguage: ['en', 'ja'],
  publisher: { '@id': orgId },
};
const webPageLd = {
  '@type': 'WebPage',
  '@id': pageId,
  url: canonical,
  name: title,
  description,
  inLanguage: locale,
  isPartOf: { '@id': websiteId },
  about: { '@id': orgId },
  potentialAction: [{ '@type': 'ReadAction', target: [canonical] }],
};
const extraLd = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const graphLd = {
  '@context': 'https://schema.org',
  '@graph': [orgLd, websiteLd, webPageLd, ...extraLd],
};
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    {/* Auto language redirect: ja browser -> /ja, anything else -> EN.
        Runs before paint. Respects a saved manual choice; never redirects an
        EN-only page (no JA mirror). */}
    <script is:inline define:vars={{ pageEnOnly: enOnly }}>
      (function () {
        try {
          var KEY = 'jayp-lang';
          var path = location.pathname.replace(/\/+$/, '') || '/';
          var isJa = path === '/ja' || path.indexOf('/ja/') === 0;
          var current = isJa ? 'ja' : 'en';
          var slug = isJa ? (path === '/ja' ? '/' : path.slice(3)) : path;

          var stored = null;
          try { stored = localStorage.getItem(KEY); } catch (e) {}

          var target = stored;
          if (target !== 'en' && target !== 'ja') {
            var langs =
              navigator.languages && navigator.languages.length
                ? navigator.languages
                : [navigator.language || 'en'];
            target = String(langs[0] || 'en').toLowerCase().indexOf('ja') === 0 ? 'ja' : 'en';
            try { localStorage.setItem(KEY, target); } catch (e) {}
          }

          if (target === current) return;

          var dest;
          if (target === 'ja') {
            if (pageEnOnly) return; // this page has no JA mirror
            dest = slug === '/' ? '/ja' : '/ja' + slug;
          } else {
            dest = slug; // every JA page has an EN mirror
          }

          if (dest && dest !== path) {
            location.replace(dest + location.search + location.hash);
          }
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={metaKeywords} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    {siteConfig.googleSiteVerification && (
      <meta name="google-site-verification" content={siteConfig.googleSiteVerification} />
    )}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={abs(enPath)} />
    {!enOnly && <link rel="alternate" hreflang="ja" href={abs(jaPath)} />}
    <link rel="alternate" hreflang="x-default" href={abs(enPath)} />

    <link rel="icon" type="image/png" sizes="512x512" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Noto+Sans+JP:wght@300;400;500;700&family=Noto+Serif+JP:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(graphLd)} />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      // Remember an explicit language switch so the auto-redirect stops fighting it.
      document.addEventListener(
        'click',
        (e) => {
          const a = e.target.closest && e.target.closest('[data-set-lang]');
          if (a) {
            try {
              localStorage.setItem('jayp-lang', a.getAttribute('data-set-lang'));
            } catch (_) {}
          }
        },
        true
      );

      const revealEls = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window && revealEls.length) {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        revealEls.forEach((el) => io.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add('is-visible'));
      }

      const nav = document.getElementById('site-nav');
      if (nav) {
        const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 30);
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }

      // Count-up stats (animate 0 → value when scrolled into view)
      const countEls = document.querySelectorAll('[data-count]');
      if (countEls.length) {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const fmt = (n) => n.toLocaleString();
        const run = (el) => {
          const target = parseFloat(el.getAttribute('data-count')) || 0;
          if (reduce || !('requestAnimationFrame' in window)) {
            el.textContent = fmt(target);
            return;
          }
          const dur = 1300;
          const start = performance.now();
          const tick = (now) => {
            const p = Math.min((now - start) / dur, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = fmt(Math.round(eased * target));
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        };
        if ('IntersectionObserver' in window) {
          const co = new IntersectionObserver(
            (entries, obs) => {
              entries.forEach((e) => {
                if (e.isIntersecting) {
                  run(e.target);
                  obs.unobserve(e.target);
                }
              });
            },
            { threshold: 0.4 }
          );
          countEls.forEach((el) => co.observe(el));
        } else {
          countEls.forEach(run);
        }
      }
    </script>
  </body>
</html>
