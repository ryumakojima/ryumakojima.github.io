---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionLabel from '../components/SectionLabel.astro';
import MiniBars from '../components/MiniBars.astro';
import PhotoWall from '../components/PhotoWall.astro';
import Stats from '../components/Stats.astro';
import PastEvents from '../components/PastEvents.astro';
import Partners from '../components/Partners.astro';
import Updates from '../components/Updates.astro';
import { updates } from '../data/updates';
import { getSignupUrl } from '../config';

import savannaGrassland from '../assets/photos/savanna-grassland.jpg';
import cafeViewArusha from '../assets/photos/cafe-view-arusha.jpg';
import foodArusha from '../assets/photos/food-arusha.jpg';
import teachingJapaneseClass from '../assets/photos/teaching-japanese-class.jpg';

const signup = getSignupUrl('en');

// ← Edit these numbers as the community grows
const reachStats = [
  { value: 7, suffix: '', label: 'African countries reached' },
  { value: 20, suffix: '+', label: 'Members' },
];

const faqLd = {
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Japan-Africa Young Professionals?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Japan-Africa Young Professionals is a Japan-Africa exchange community in Japan connecting young generations through networking, culture, and sport.',
      },
    },
    {
      '@type': 'Question',
      name: 'Who can join JAYP?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Young professionals, students, African residents in Japan, volunteers, partners, and anyone interested in African culture, language, business, or development can join.',
      },
    },
    {
      '@type': 'Question',
      name: 'When is the first Japan-Africa event?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The first event, Japan-Africa Young Professionals Connection Party, is planned for around November 2026 in Japan. Date and venue will be announced later.',
      },
    },
  ],
};
---

<BaseLayout
  title="Japan-Africa Young Professionals | Japan Africa Community in Japan"
  description="A Japan-Africa exchange community in Japan connecting young professionals, students, and the African community through networking events, culture, and sport."
  keywords={[
    'Japan Africa community in Japan',
    'Japan Africa networking',
    'African community in Japan',
    'Japan Africa events',
    'Africa culture Japan',
  ]}
  jsonLd={faqLd}
>
  <Hero
    image={savannaGrassland}
    alt="Open savanna under a wide sky"
    eyebrow="Japan-Africa Connection"
    headline={`A youth-led bridge\nbetween Japan and Africa.`}
    subhead="An organization deepening exchange between young generations across Africa and Japan."
    ctaLabel="Join Us !"
    ctaHref={signup}
  />

  <!-- Why -->
  <section class="section section-white reveal">
    <div class="wrap why">
      <div class="why-text">
        <SectionLabel eyebrow="Why JAYP" heading="A place for young generations to meet." />
        <p>Every year, more young people from Japan connect with Africa through study, volunteering, work, and travel. At the same time, more young Africans are coming to Japan to study, work, and build new lives.</p>
        <p>But there are still few events or organizations that consistently bring young generations from both sides together. So we are building one.</p>
        <p>JAYP is a starting point for anyone looking for a Japan-Africa exchange community or events where they can experience African culture in Japan.</p>
      </div>
      <div class="evidence-stack">
        <MiniBars
          title="African residents in Japan"
          bars={[
            { label: '2000', display: '3,840', pct: 15 },
            { label: '2010', display: '8,917', pct: 35 },
            { label: '2024', display: '25,283', pct: 100 },
          ]}
          source="Source: Immigration Services Agency of Japan, Statistics on Foreign Residents."
        />
        <div class="flow-card reveal">
          <p class="flow-kicker">Japan → Africa is rising too</p>
          <p>
            Japan's overseas-residents statistics show Africa as one of the regions
            where Japanese residents increased, even while the global total fell.
          </p>
          <p class="flow-source">
            Source: Ministry of Foreign Affairs of Japan, Overseas Residents Statistics;
            nippon.com summary, 2023.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Reach stats -->
  <section class="section section-dark reveal" style="padding-block: clamp(2.5rem, 6vw, 4.2rem);">
    <div class="wrap text-center">
      <SectionLabel eyebrow="Our reach so far" center />
      <div style="margin-top:1.6rem;">
        <Stats items={reachStats} />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-white reveal">
    <div class="wrap faq">
      <SectionLabel eyebrow="FAQ" heading="Common questions." center />
      <div class="faq-grid">
        <article>
          <h3>What is JAYP?</h3>
          <p>A Japan-Africa exchange community in Japan for networking, cultural exchange, and sport.</p>
        </article>
        <article>
          <h3>Who can join?</h3>
          <p>Young professionals, students, African residents in Japan, volunteers, partners, and friends of Africa.</p>
        </article>
        <article>
          <h3>When is the first event?</h3>
          <p>Japan-Africa Young Professionals Connection Party is planned for around November 2026. Date and venue TBD.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- First event -->
  <section class="section section-sand reveal">
    <div class="wrap text-center event-block">
      <SectionLabel eyebrow="Connection Party · Around November 2026" center />
      <h2>Japan-Africa Young Professionals Connection Party</h2>
      <p class="lead measure-center">
        A relaxed event to deepen connections. Students, working professionals,
        and anyone interested in Africa can join. Spots are limited and
        first-come, first-served. So stay tuned !
      </p>
      <div class="actions center">
        <a href="/connection-party" class="btn btn-solid">See details</a>
      </div>
    </div>
  </section>

  {updates.length > 0 && (
    <section class="section section-white reveal">
      <div class="wrap">
        <SectionLabel eyebrow="Updates" heading="What we've been up to." center />
        <div style="margin-top:2.2rem;">
          <Updates />
        </div>
      </div>
    </section>
  )}

  {/* Past events — hidden until we have real events to show
  <section class="section section-white reveal">
    <div class="wrap">
      <SectionLabel eyebrow="Past Events" heading="Where we've been." center />
      <div style="margin-top:2.2rem;">
        <PastEvents
          items={[
            { image: cafeViewArusha, name: 'Connection Party', date: '2026.04.19' },
            { image: foodArusha, name: 'Culture Night', date: '2026.02.14' },
            { image: teachingJapaneseClass, name: 'Language Meetup', date: '2025.12.07' },
          ]}
        />
      </div>
    </div>
  </section>
  */}

  {/* Partners — hidden until we have real partner organizations
  <section class="section section-sand reveal">
    <div class="wrap">
      <SectionLabel eyebrow="Partners" heading="Building it together." center />
      <div style="margin-top:2.2rem;">
        <Partners
          items={[
            { logo: '/logo-placeholder.svg', name: 'Partner One' },
            { logo: '/logo-placeholder.svg', name: 'Partner Two' },
            { logo: '/logo-placeholder.svg', name: 'Partner Three' },
            { logo: '/logo-placeholder.svg', name: 'Partner Four' },
          ]}
        />
      </div>
    </div>
  </section>
  */}

  {/* Community wall — temporarily hidden
  <section class="section section-white reveal">
    <div class="wrap">
      <SectionLabel eyebrow="Community Wall" heading="Share your moments." center />
      <PhotoWall
        items={[
          { nickname: 'Aya', location: 'Tokyo' },
          { nickname: 'Kwame', location: 'Osaka' },
          { nickname: 'Mariam', location: 'Nagoya' },
        ]}
        note="After our first event, anyone can post a photo — just a nickname and a place. (Example posts shown.)"
        postLabel="Post a photo"
        postHref={signup}
      />
    </div>
  </section>
  */}

  <!-- CTA -->
  <section class="section section-dark text-center reveal">
    <div class="wrap">
      <h2>Join Us !</h2>
      <div class="actions center">
        <a href={signup} class="btn btn-solid" target="_blank" rel="noopener">Sign up</a>
        <a href="/get-involved" class="btn btn-light">See the benefits</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .why {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .why-text p {
    color: var(--text-soft);
  }
  .evidence-stack {
    display: grid;
    gap: 1rem;
  }
  .flow-card {
    background: var(--dark);
    color: var(--text-on-dark);
    border-radius: 12px;
    padding: 1.25rem 1.35rem;
  }
  .flow-card p {
    margin: 0;
  }
  .flow-card p + p {
    margin-top: 0.7rem;
  }
  .flow-kicker {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .flow-source {
    font-size: 0.72rem;
    line-height: 1.5;
    color: var(--text-on-dark-soft);
  }
  .faq-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }
  .faq-grid article {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.35rem;
    background: var(--paper);
  }
  .faq-grid h3 {
    font-size: var(--text-lg);
    margin-bottom: 0.45rem;
  }
  .faq-grid p {
    color: var(--text-soft);
    font-size: var(--text-sm);
    margin: 0;
  }
  .reach {
    margin-top: 1.4rem;
    color: var(--text) !important;
    font-weight: 500;
  }
  .reach strong {
    color: var(--gold-dark);
  }
  .event-block h2 {
    font-size: var(--text-3xl);
  }
  @media (max-width: 860px) {
    .why {
      grid-template-columns: 1fr;
    }
    .faq-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
