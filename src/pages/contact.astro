---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { Picture } from 'astro:assets';
import { siteConfig, getSignupUrl } from '../config';

import zebraWaterhole from '../assets/photos/zebra-waterhole.jpg';
import insideTheBus from '../assets/photos/inside-the-bus.jpg';

const signup = getSignupUrl('en');
const signupExternal = signup.startsWith('http');
---

<BaseLayout
  title="Contact JAYP | Japan Africa Community in Japan"
  description="Contact Japan-Africa Young Professionals to join a Japan-Africa event, connect with the African community in Japan, volunteer, or partner with us."
  keywords={[
    'contact Japan Africa community',
    'Japan Africa event contact',
    'African community Japan contact',
  ]}
>
  <Hero
    image={zebraWaterhole}
    alt="Zebras at a watering hole"
    eyebrow="Contact"
    headline="Say hello."
    height="short"
  />

  <section class="section section-white">
    <div class="wrap contact-grid">
      <div class="reveal">
        <SectionLabel eyebrow="Get in Touch" heading="Come to an event, or help build it." />
        <p class="lead measure">
          The easiest way in is to get on the invite list — we'll let you know
          about the first event and how to join.
        </p>
        <div class="actions">
          <a href={signup} class="btn btn-solid" {...(signupExternal ? { target: '_blank', rel: 'noopener' } : {})}>Get an invite</a>
        </div>

        {(siteConfig.instagram || siteConfig.x || siteConfig.email) && (
          <div class="contact-block">
            <p class="contact-eyebrow">Find us</p>
            <ul class="contact-list">
              {siteConfig.instagram && <li><a href={siteConfig.instagram} target="_blank" rel="noopener">Instagram</a></li>}
              {siteConfig.x && <li><a href={siteConfig.x} target="_blank" rel="noopener">X</a></li>}
              {siteConfig.email && <li><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>}
            </ul>
          </div>
        )}
      </div>

      <div class="reveal">
        <div class="feature-frame">
          <div class="ratio ratio-43">
            <Picture
              src={insideTheBus}
              alt="On the road"
              widths={[400, 640, 960]}
              sizes="(min-width: 900px) 42vw, 100vw"
              formats={['avif', 'webp', 'jpg']}
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .contact-block {
    margin-top: 2.5rem;
  }
  .contact-eyebrow {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold-dark);
    margin-bottom: 0.7rem;
  }
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .feature-frame {
    position: relative;
    border: 6px double rgba(197, 160, 89, 0.5);
    padding: 8px;
    border-radius: 6px;
    background: var(--paper);
    box-shadow: 0 24px 50px -28px rgba(30, 43, 38, 0.55);
    transform: rotate(0.8deg);
    transition: transform 0.5s ease;
  }
  .feature-frame:hover {
    transform: rotate(0);
  }
  .feature-frame .ratio {
    border-radius: 3px;
  }
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .contact-grid > div:last-child {
      order: -1;
    }
  }
</style>
