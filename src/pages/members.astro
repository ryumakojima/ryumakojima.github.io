---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { siteConfig } from '../config';

const f = siteConfig.founder;
---

<BaseLayout
  title="Members | Japan-Africa Young Professionals Community"
  description="Meet the people building Japan-Africa Young Professionals, a Japan-Africa exchange community connecting people through events, culture, and sport."
  keywords={[
    'Japan-Africa Young Professionals members',
    'JAYP members',
    'Japan Africa community team',
  ]}
  enOnly
>
  <section class="section section-white page-head">
    <div class="wrap">
      <SectionLabel eyebrow="Members" heading="The people behind it." />
      <p class="lead measure">
        We're just getting started, so the team is small and growing with every
        event. Want to see your name here? Come help out.
      </p>
    </div>
  </section>

  <section class="section section-sand reveal" style="padding-top:0;">
    <div class="wrap member-grid">
      <article class="member">
        {f.photo
          ? <img class="avatar avatar-photo" src={f.photo} alt={f.name} width="64" height="64" loading="lazy" />
          : <span class="avatar">{f.name.split(' ').map((w) => w[0]).join('')}</span>}
        <h3>{f.name}</h3>
        <p class="role">Founder</p>
        <p class="bio">{f.blurb}</p>
        <a href={f.url} target="_blank" rel="noopener" class="member-link">Website ↗</a>
      </article>

      <article class="member open">
        <span class="avatar open-avatar">+</span>
        <h3>Your name here</h3>
        <p class="role">Organizer · Volunteer</p>
        <p class="bio">We're looking for people to help plan and run events.</p>
        <a href="/get-involved" class="member-link">Get involved →</a>
      </article>

      <article class="member open">
        <span class="avatar open-avatar">+</span>
        <h3>Your name here</h3>
        <p class="role">Organizer · Volunteer</p>
        <p class="bio">Students and working people both welcome.</p>
        <a href="/get-involved" class="member-link">Get involved →</a>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-top: calc(var(--nav-height) + 3rem);
    padding-bottom: 2rem;
  }
  .member-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.6rem;
  }
  .member {
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem 1.8rem;
    text-align: center;
  }
  .member.open {
    border-style: dashed;
    background: transparent;
  }
  .avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border-radius: 999px;
    background: var(--dark);
    color: var(--gold);
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }
  .open-avatar {
    background: var(--sand-deep);
    color: var(--gold-dark);
    font-size: 1.6rem;
  }
  .avatar-photo {
    object-fit: cover;
    background: #fff;
    border: 2px solid var(--gold);
    padding: 0;
  }
  .member h3 {
    font-size: var(--text-xl);
    margin-bottom: 0.2em;
  }
  .role {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold-dark);
    margin-bottom: 0.8em;
  }
  .bio {
    color: var(--text-soft);
    font-size: var(--text-sm);
    margin-bottom: 1em;
  }
  .member-link {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  @media (max-width: 860px) {
    .member-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
