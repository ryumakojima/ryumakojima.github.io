---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionLabel from '../components/SectionLabel.astro';

import cafeViewArusha from '../assets/photos/cafe-view-arusha.jpg';

const eventLd = {
  '@type': 'Event',
  name: 'Japan-Africa Young Professionals Connection Party',
  description:
    'The first Japan-Africa Young Professionals connection party is planned for around November 2026. Date and venue are to be announced.',
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  startDate: '2026-11',
  location: {
    '@type': 'Place',
    name: 'To be announced',
    address: {
      '@type': 'PostalAddress',
      addressCountry: 'JP',
    },
  },
  organizer: {
    '@type': 'Organization',
    name: 'Japan-Africa Young Professionals',
  },
};
---

<BaseLayout
  title="Japan-Africa Young Professionals Connection Party | November 2026"
  description="The first Japan-Africa Young Professionals Connection Party is planned for around November 2026. Date, venue, and sign-up details are still to be announced."
  keywords={[
    'Japan-Africa Young Professionals Connection Party',
    'Japan Africa connection party',
    'Japan Africa networking event',
    'African community event Japan',
  ]}
  jsonLd={eventLd}
>
  <Hero
    image={cafeViewArusha}
    alt="A town view at golden hour"
    eyebrow="First Event"
    headline="Japan-Africa Young Professionals Connection Party"
    subhead="Planned for around November 2026. Date and venue are still to be announced."
    height="short"
  />

  <section class="section section-white reveal">
    <div class="wrap party-grid">
      <div>
        <SectionLabel eyebrow="First Event" heading="Connection Party" />
        <p class="lead">
          The first event where people in Japan interested in Africa and people
          with African roots living in Japan can meet casually.
        </p>
      </div>

      <aside class="event-card">
        <dl>
          <div>
            <dt>When</dt>
            <dd>Around November 2026</dd>
          </div>
          <div>
            <dt>Date</dt>
            <dd>To be announced</dd>
          </div>
          <div>
            <dt>Venue</dt>
            <dd>To be announced</dd>
          </div>
          <div>
            <dt>Sign-up</dt>
            <dd>To be announced</dd>
          </div>
        </dl>
        <p class="event-note">Sign-up opens closer to the date — check back soon.</p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .party-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .party-grid p {
    color: var(--text-soft);
  }
  .event-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--paper);
    padding: 1.5rem;
  }
  .event-card dl {
    display: grid;
    gap: 1rem;
    margin: 0 0 1.4rem;
  }
  .event-card div {
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.85rem;
  }
  .event-card div:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }
  .event-card dt {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-dark);
    margin-bottom: 0.2rem;
  }
  .event-card dd {
    margin: 0;
    color: var(--text);
    font-weight: 600;
  }
  .event-note {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-soft);
  }
  @media (max-width: 860px) {
    .party-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
