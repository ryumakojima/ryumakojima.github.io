---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { getSignupUrl } from '../config';

import cafeViewArusha from '../assets/photos/cafe-view-arusha.jpg';

const signup = getSignupUrl('en');
---

<BaseLayout
  title="Japan Africa Events in Japan | Connection Party 2026"
  description="Japan-Africa Young Professionals Connection Party is a Japan-Africa networking event planned for around November 2026. Date and venue are to be announced."
  keywords={[
    'Japan Africa event',
    'Japan Africa networking event',
    'African community event Japan',
    'Japan-Africa Young Professionals Connection Party',
  ]}
>
  <Hero
    image={cafeViewArusha}
    alt="A view over a town"
    eyebrow="Events"
    headline="Connection Party"
    height="short"
  />

  <section class="section section-white reveal">
    <div class="wrap text-center event">
      <SectionLabel eyebrow="Coming Up · Around November 2026" center />
      <h2>Japan-Africa Young Professionals Connection Party</h2>
      <p class="lead measure-center">
        A relaxed event to deepen connections. Students, working professionals,
        and anyone interested in Africa can join.
      </p>
      <p class="urgent">Spots are limited and given first-come, first-served.</p>
      <div class="actions center">
        <a href="/connection-party" class="btn btn-solid">See details</a>
      </div>
      {/* <p class="note">Date and venue to be announced. Details will go to the email list first.</p> */}
    </div>
  </section>
</BaseLayout>

<style>
  .event h2 {
    font-size: var(--text-3xl);
  }
  .urgent {
    color: var(--accent);
    font-weight: 600;
    margin-top: 0.4rem;
  }
  .note {
    margin-top: 2.4rem;
    font-size: var(--text-sm);
    color: var(--text-soft);
  }
</style>
