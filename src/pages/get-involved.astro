---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CardGrid from '../components/CardGrid.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { getSignupUrl } from '../config';

import elephantsSideways1 from '../assets/photos/elephants-sideways-1.jpg';

const signup = getSignupUrl('en');
---

<BaseLayout
  title="Join a Japan Africa Community in Japan | JAYP"
  description="Join Japan-Africa Young Professionals if you are in Japan and interested in Africa, the African community in Japan, volunteering, events, or partnerships."
  keywords={[
    'join Japan Africa community',
    'African community in Japan',
    'Africa volunteer Japan',
    'Japan Africa partnership',
  ]}
>
  <Hero
    image={elephantsSideways1}
    alt="Elephants in the open savanna"
    eyebrow="Get Involved"
    headline="Join us."
    height="short"
  />

  <section class="section section-white reveal">
    <div class="wrap">
      <SectionLabel eyebrow="Who Can Join" heading="Everyone's welcome." center />
      <div style="margin-top:2.2rem;">
        <CardGrid
          items={[
            { icon: 'students', accent: 'gold', heading: 'In Japan, into Africa', body: 'Anyone curious about African culture, language, business, or development — students and working people.', ctaLabel: 'Say hello', ctaHref: '/contact' },
            { icon: 'partner', accent: 'accent', heading: 'African community in Japan', body: 'From any country, living in Japan. Come meet people.', ctaLabel: 'Say hello', ctaHref: '/contact' },
            { icon: 'volunteer', accent: 'green', heading: 'Volunteers & partners', body: 'Help run events, or partner with us as a company or school.', ctaLabel: 'Say hello', ctaHref: '/contact' },
          ]}
        />
      </div>
    </div>
  </section>

  <section class="section section-dark text-center reveal">
    <div class="wrap">
      <h2>Want in?</h2>
      <div class="actions center">
        <a href={signup} class="btn btn-solid" target="_blank" rel="noopener">Join us</a>
      </div>
    </div>
  </section>
</BaseLayout>
